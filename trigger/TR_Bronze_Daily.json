{
  "name": "TR_Bronze_Daily",
  "properties": {
    "description": "Runs PL_Bronze_Daily once a day at 02:00 UTC.",
    "annotations": [ "bronze" ],
    "runtimeState": "Stopped",
    "pipelines": [
      {
        "pipelineReference": {
          "referenceName": "PL_Bronze_Daily",
          "type": "PipelineReference"
        },
        "parameters": {
          "runIngest": true,
          "runPublish": true,
          "runPublishMetrics": true,
          "batchIdOverride": "",
          "profileFilter": [],
          "failIfNoProfiles": true,
          "profilesFileSystem": "config",
          "profilesFolderPath": "bronze/profiles",
          "configRoot": "abfss://config@SET_YOUR_ACCOUNT.dfs.core.windows.net/bronze",
          "logLevel": "INFO"
        }
      }
    ],
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2026-01-01T02:00:00",
        "timeZone": "UTC",
        "schedule": {
          "hours": [ 2 ],
          "minutes": [ 0 ]
        }
      }
    }
  }
}
